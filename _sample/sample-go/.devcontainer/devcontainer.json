{
  "name": "go-devcontainer",
  "image": "mcr.microsoft.com/devcontainers/go",
  "remoteUser": "vscode",
  "runArgs": ["--name", "go-devcontainer-sample"],
  "features": {
    // "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "configureZshAsDefaultShell": false
    }
  },
  "dotfiles": {
    "repository": "https://github.com/druchtx/dotfiles",
    "targetPath": "~/.dotfiles",
    "installCommand": "bootstrap",
    "branch": "devcontainer"
  },
  // "postCreateCommand": [
  //   "sh",
  //   "-c",
  //   "if [ ! -d ~/.dotfiles ]; then git clone -b devcontainer https://github.com/druchtx/dotfiles ~/.dotfiles; fi && cd ~/.dotfiles && ./bootstrap"
  // ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces,type=bind",
  "workspaceFolder": "/workspaces/",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.Go"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "mounts": [
    "source=vol-vsc-go,target=/home/vscode,type=volume"
  ]
}