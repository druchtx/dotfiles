{
  "name": "go-devcontainer",
  "image": "mcr.microsoft.com/devcontainers/go:1-1.22-bookworm",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true
    }
  },
  "postCreateCommand": [
    "sh",
    "-c",
    "if [ ! -d ~/.dotfiles ]; then git clone -b devcontainer https://github.com/druchtx/dotfiles ~/.dotfiles; fi && cd ~/.dotfiles && ./bootstrap"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/go,type=bind",
  "workspaceFolder": "/workspaces/go",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.Go"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "mounts": [
    "source=vol-vsc-go,target=/home/vscode,type=volume"
  ]
}
