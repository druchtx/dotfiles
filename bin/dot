#!/bin/sh
#
# dot
#
# Helper for managing dotfiles

set -e

DOTFILES_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

displayUsageAndExit() {
    echo "Usage: dot <command>"
    echo ""
    echo "Commands:"
    echo "  up, update    Update dotfiles (git pull + bootstrap)"
    echo "  e,  edit      Edit a file in dotfiles (using fzf)"
    echo "  c,  cd        Go to dotfiles directory (spawns new shell)"
    echo "  o,  open      Open dotfiles directory in editor"
    echo "  h,  help      Show this help message"
    exit 0
}

# If no arguments, show usage
if [ $# -eq 0 ]; then
    displayUsageAndExit
fi

case "$1" in
    "up"|"update")
        echo "Updating dotfiles..."
        if [ -d "$DOTFILES_ROOT/.git" ]; then
            git -C "$DOTFILES_ROOT" pull
        fi
        "$DOTFILES_ROOT/bootstrap"
        ;;
    "e"|"edit")
        cd "$DOTFILES_ROOT"
        if ! command -v fzf >/dev/null 2>&1; then
            echo "Error: fzf is not installed."
            exit 1
        fi
        # Use find to list files, excluding .git, pass to fzf, then open with EDITOR
        FILE=$(find . -path '*/.git*' -prune -o -type f -print | sed 's/^\.\///' | fzf)
        if [ -n "$FILE" ]; then
            exec "${EDITOR:-vim}" "$DOTFILES_ROOT/$FILE"
        fi
        ;;
    "c"|"cd")
        echo "Spawning shell in $DOTFILES_ROOT..."
        cd "$DOTFILES_ROOT"
        exec "${SHELL:-/bin/sh}"
        ;;
    "o"|"open")
        echo "Opening $DOTFILES_ROOT..."
        exec "${EDITOR:-vim}" "$DOTFILES_ROOT"
        ;;
    "h"|"help")
        displayUsageAndExit
        ;;
    *)
        echo "Unknown command: $1"
        displayUsageAndExit
        ;;
esac